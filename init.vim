set nocompatible

set encoding=utf-8
syntax on

set number
set hlsearch

filetype indent plugin on
set autoindent
set smartindent
"set cindent

set clipboard=unnamedplus
set showmatch
set showmode
set hlsearch
set laststatus=2
"set nowrap

set expandtab
set tabstop=4
set softtabstop=4
set shiftwidth=4

set mouse=a
set sms

inoremap ( ()<Esc>i
inoremap [ []<Esc>i
inoremap " ""<Esc>i
inoremap ' ''<Esc>i
inoremap ` ``<Esc>i
inoremap { {}<Esc>i
